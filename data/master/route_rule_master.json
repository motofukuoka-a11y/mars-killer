{
  "id": "ROUTE_RULE_MASTER",
  "name": "経路規則マスター",
  "enabled": true,
  "description": "経路特定区間、区間外乗車、選択乗車および折返し乗車を管理する。",
  "references": [
    {
      "master": "line_master",
      "relation": "line_ids"
    },
    {
      "master": "station_master",
      "relation": "station_ids"
    },
    {
      "master": "distance_master",
      "relation": "distance_ids"
    }
  ],
  "priority": 0,
  "records": [
    {
      "id": "SPECIFIC_ROUTE_SECTION",
      "name": "経路特定区間",
      "enabled": true,
      "description": "経路特定区間の対象経路を判定する。",
      "conditions": {
        "required_fields": [
          "specific_route_section_applicable"
        ],
        "all": [
          {
            "field": "specific_route_section_applicable",
            "operator": "equals",
            "value": true
          }
        ],
        "result_key": "specific_route_section",
        "applicable_reason": "指定された経路は経路特定区間の対象です。",
        "not_applicable_reason": "指定された経路は経路特定区間の対象外です。",
        "missing_input_reason": "経路特定区間の判定には経路マスターによる対象判定が必要です。"
      },
      "references": [],
      "priority": 300,
      "metadata": {
        "company_ids": [],
        "line_ids": [],
        "station_ids": [],
        "distance_ids": []
      }
    },
    {
      "id": "OUTSIDE_SECTION_RIDE",
      "name": "区間外乗車",
      "enabled": true,
      "description": "区間外乗車の対象経路を判定する。",
      "conditions": {
        "required_fields": [
          "outside_section_ride_applicable"
        ],
        "all": [
          {
            "field": "outside_section_ride_applicable",
            "operator": "equals",
            "value": true
          }
        ],
        "result_key": "outside_section_ride",
        "applicable_reason": "指定された経路は区間外乗車の対象です。",
        "not_applicable_reason": "指定された経路は区間外乗車の対象外です。",
        "missing_input_reason": "区間外乗車の判定には経路マスターによる対象判定が必要です。"
      },
      "references": [],
      "priority": 400,
      "metadata": {
        "company_ids": [],
        "line_ids": [],
        "station_ids": [],
        "distance_ids": []
      }
    },
    {
