      "name": "選択乗車",
      "enabled": true,
      "description": "選択乗車の対象経路を判定する。",
      "conditions": {
        "required_fields": [
          "selected_route_applicable"
        ],
        "all": [
          {
            "field": "selected_route_applicable",
            "operator": "equals",
            "value": true
